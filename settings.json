{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 36500,
  "spinnerTipsEnabled": false,
  "autoMemoryEnabled": false,
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "MAX_THINKING_TOKENS": "128000"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git add:*)"
    ],
    "ask": [
      "Bash(rm:*)"
    ]
  },
  "enabledMcpjsonServers": [
    "context7"
  ],
  "disabledMcpjsonServers": [
    "ide"
  ],
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notification-handler.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/auto-format-ts.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/auto-format-go.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/auto-lint-fix-ts.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'CRITICAL: Follow all rules in CLAUDE.md! NEVER EVER USE ANY IN TYPESCRIPT NO MATTER WHAT - SUPER IMPORTANT! NEVER SKIP TESTS Unless explicitly asked for and confirmed by the user! CHECK SKILLS: Before responding, check if user request matches any and use the Skill tool if ANY skill is relevant!'"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/skill-activation-prompt-bash.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/inject-current-directory.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "outputStyle": "Explanatory",
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "CAN DO",
      "LOOK AT ME",
      "I'M MR MEESEEKS",
      "Existence is pain",
